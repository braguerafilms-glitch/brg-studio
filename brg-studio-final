/* AI */
.ai-wrap{background:var(–ink3);border:1px solid var(–fog);border-radius:3px;padding:9px;margin-bottom:9px;transition:border-color var(–ease),box-shadow var(–ease)}
.ai-wrap:focus-within{border-color:rgba(192,57,43,.4);box-shadow:0 0 0 3px rgba(192,57,43,.07)}
.ai-wrap textarea{background:transparent;border:none;color:var(–paper);font-size:11.5px;width:100%;resize:none;min-height:70px;font-family:var(–sans);outline:none;line-height:1.55}
.ai-wrap textarea::placeholder{color:var(–dust)}
.btn-ai{
width:100%;background:var(–red);color:#fff;border:none;padding:10px;
font-size:10px;font-weight:600;letter-spacing:.12em;cursor:pointer;
text-transform:uppercase;border-radius:3px;font-family:var(–sans);
transition:all var(–ease);display:flex;align-items:center;justify-content:center;gap:7px;
}
.btn-ai:hover{background:var(–red-hi);transform:translateY(-1px);box-shadow:0 4px 14px rgba(192,57,43,.35)}
.btn-ai:active{transform:scale(.98);box-shadow:none}
.btn-ai:disabled{opacity:.35;cursor:not-allowed;transform:none;box-shadow:none}
.ai-st{font-size:9px;color:var(–dust);text-align:center;margin-top:6px;min-height:13px;font-family:var(–mono)}
.chips{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:10px}
.chip{
background:var(–ink3);border:1px solid var(–fog);color:var(–dust);
font-size:9px;padding:4px 10px;cursor:pointer;border-radius:100px;
transition:all var(–ease);white-space:nowrap;
}
.chip:hover{border-color:rgba(192,57,43,.4);color:var(–paper);background:rgba(192,57,43,.06);transform:translateY(-1px)}
.spin{width:11px;height:11px;border:1.5px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:sp .7s linear infinite;flex-shrink:0}
@keyframes sp{to{transform:rotate(360deg)}}

/* EXPORT PANEL */
.exp-section{background:var(–ink3);border:1px solid var(–fog);border-radius:3px;padding:10px;margin-bottom:8px}
.exp-section-title{font-size:8px;letter-spacing:.14em;text-transform:uppercase;color:var(–dust);margin-bottom:8px}
.exp-slides{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:8px}
.exp-thumb{width:44px;border-radius:2px;overflow:hidden;border:1.5px solid transparent;cursor:pointer;transition:all var(–ease);position:relative;flex-shrink:0}
