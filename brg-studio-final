    }
    // curved bottom (handle/cta)
    const bl2=(s.handle||s.cta||'');
    if(bl2){
      const t3=bl2.toUpperCase();
      ctx.save();ctx.font=FM(7.5*sc);ctx.fillStyle=ac;ctx.globalAlpha=ao*0.6;
      const ar2=sr+2*sc,span2=Math.min(t3.length*0.16,Math.PI*0.95),sa2=Math.PI/2-span2/2;
      for(let i=0;i<t3.length;i++){
        const a=sa2+i*(span2/(Math.max(t3.length-1,1)));
        ctx.save();ctx.translate(cx2+ar2*Math.cos(a),cy2+ar2*Math.sin(a));
        ctx.rotate(a-Math.PI/2);ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(t3[i],0,0);ctx.restore();
      }
      ctx.restore();ctx.globalAlpha=1;
    }
    numIdx(W-24*sc,18*sc,'right');

  /* ══════════════════════════════════════
     TICKER — streetwear / broadcast bands
  ══════════════════════════════════════ */
  } else if(lay==='ticker'){
    grain(0.5);
    const b1=H*0.13,b2=H*0.87,bh=19*sc;
    // band fills
    ctx.fillStyle=ac;ctx.globalAlpha=ao*0.08;
    ctx.fillRect(0,b1-bh/2,W,bh);ctx.fillRect(0,b2-bh/2,W,bh);ctx.globalAlpha=1;
    // band rules — double lines
    [[b1],[b2]].forEach(([b])=>{
      ctx.fillStyle=ac;ctx.globalAlpha=ao;
      ctx.fillRect(0,b-bh/2,W,0.9*sc);ctx.fillRect(0,b+bh/2,W,0.9*sc);
      ctx.globalAlpha=1;
    });
    // scrolling text inside bands
    [{y:b1,txt:(s.sub||s.title||'BRG').toUpperCase()},{y:b2,txt:(s.handle||s.cta||'@BRGFILMS').toUpperCase()}].forEach(({y,txt})=>{
      ctx.font=FM(8.5*sc);ctx.fillStyle=ac;ctx.globalAlpha=ao*0.65;ctx.textBaseline='middle';ctx.textAlign='left';
      const sep='  ·  ';const fw=ctx.measureText(txt+sep).width;
      let xi=0;while(xi<W+fw){ctx.fillText(txt+sep,xi,y);xi+=fw;}
      ctx.globalAlpha=1;
    });
    // main content zone
    ctx.fillStyle=tc2;ctx.textAlign='left';ctx.textBaseline='middle';
    wt(s.title,28*sc,s.body?H*0.46:H*0.5,W-56*sc,fs*lh,FD(fs,700));
    bodyTxt(s.body,28*sc,H*0.65,W-56*sc);
    // ghost index
    if(s.showNum){
      ctx.font=`700 ${fs*2.8}px ${fnt}`;ctx.fillStyle=ac;ctx.globalAlpha=ao*0.03;
      ctx.textAlign='right';ctx.textBaseline='bottom';
      ctx.fillText(String(idx+1).padStart(2,'0'),W-20*sc,b2-bh/2-4*sc);ctx.globalAlpha=1;
    }
    numIdx(W-28*sc,H*0.22,'right');

  /* ══════════════════════════════════════
     TYPE GHOST — massive letterform background
  ══════════════════════════════════════ */
  } else if(lay==='type'){
    // massive ghost — first 2-3 chars
    const ghost=(s.title||'').replace(/\s/g,'').substring(0,2).toUpperCase();
    ctx.font=`700 ${fs*4.2}px ${fnt}`;ctx.fillStyle=tc2;ctx.globalAlpha=0.022;
    ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(ghost,xC,H*0.52);ctx.globalAlpha=1;
    // diagonal accent line
    ctx.save();ctx.strokeStyle=ac;ctx.globalAlpha=ao*0.45;ctx.lineWidth=0.7*sc;
    ctx.beginPath();ctx.moveTo(W*0.07,H*0.91);ctx.lineTo(W*0.21,H*0.09);ctx.stroke();
    ctx.restore();ctx.globalAlpha=1;
    // content
    if(s.sub){
      ctx.save();ctx.font=FM(8.5*sc);ctx.fillStyle=ac;ctx.globalAlpha=ao;
      ctx.textAlign='left';ctx.textBaseline='middle';ctx.letterSpacing=(ls+1.4*sc)+'px';
      ctx.fillText(trunc(s.sub.toUpperCase(),W-60*sc,FM(8.5*sc)),xL,H*0.29);
      ctx.letterSpacing='0px';ctx.restore();ctx.globalAlpha=1;
    }
    ctx.fillStyle=tc2;ctx.textAlign='left';ctx.textBaseline='middle';
    wt(s.title,xL,s.body?H*0.45:H*0.5,W-60*sc,fs*lh,FD(fs,600));
    bodyTxt(s.body,xL,H*0.64,W-60*sc);
    if(s.cta){ctx.font=FB(9.5*sc,500);ctx.fillStyle=ac;ctx.globalAlpha=ao;ctx.textAlign='left';ctx.textBaseline='middle';ctx.fillText(trunc(s.cta,W-60*sc,FB(9.5*sc,500)),xL,H*0.82);ctx.globalAlpha=1;}

  /* ══════════════════════════════════════
     FRAGMENT — registration marks + space
  ══════════════════════════════════════ */
  } else if(lay==='fragment'){
    grain(0.6);
    cornerMarks(18,26,0.75,0.5);
    if(s.sub){
      ctx.save();ctx.font=FM(8.5*sc);ctx.fillStyle=ac;ctx.globalAlpha=ao;
      ctx.textAlign='center';ctx.textBaseline='middle';ctx.letterSpacing=(ls+2*sc)+'px';
      ctx.fillText(trunc(s.sub.toUpperCase(),W-80*sc,FM(8.5*sc)),xC,H*0.21);
      ctx.letterSpacing='0px';ctx.restore();ctx.globalAlpha=1;
    }
    ctx.fillStyle=tc2;ctx.textAlign='center';ctx.textBaseline='middle';
    wt(s.title,xC,H*0.5,W-80*sc,fs*lh,FD(fs,700));
    bodyTxt(s.body,xC,H*0.69,W-80*sc);
    ctx.textAlign='center';ctx.textBaseline='middle';
    if(s.cta){ctx.font=FB(9.5*sc,500);ctx.fillStyle=ac;ctx.globalAlpha=ao;ctx.fillText(trunc(s.cta,W-80*sc,FB(9.5*sc,500)),xC,H*0.84);ctx.globalAlpha=1;}
    if(s.handle){ctx.font=FM(7.5*sc);ctx.fillStyle=tc2;ctx.globalAlpha=0.18;ctx.textAlign='center';ctx.textBaseline='bottom';ctx.fillText(trunc(s.handle,W-80*sc,FM(7.5*sc)),xC,H-20*sc);ctx.globalAlpha=1;}
    numIdx(32*sc,H-22*sc,'left');

  /* ══════════════════════════════════════
     SPLIT — two-zone composition
  ══════════════════════════════════════ */
  } else if(lay==='split'){
    // top zone tinted
    ctx.fillStyle=ac;ctx.globalAlpha=ao*0.08;ctx.fillRect(0,0,W,H*0.46);ctx.globalAlpha=1;
    // separator line
    ctx.fillStyle=ac;ctx.globalAlpha=ao;ctx.fillRect(0,H*0.46,W,1.2*sc);ctx.globalAlpha=1;
    if(s.sub){
      ctx.save();ctx.font=FM(8.5*sc);ctx.fillStyle=ac;ctx.globalAlpha=ao;
      ctx.textAlign='center';ctx.textBaseline='middle';ctx.letterSpacing=(ls+1.8*sc)+'px';
      ctx.fillText(trunc(s.sub.toUpperCase(),W-80*sc,FM(8.5*sc)),xC,H*0.12);
      ctx.letterSpacing='0px';ctx.restore();ctx.globalAlpha=1;
    }
    ctx.fillStyle=tc2;ctx.textAlign='center';ctx.textBaseline='middle';
    wt(s.title,xC,H*0.3,W-64*sc,fs*lh,FD(fs,700));
    bodyTxt(s.body,xC,H*0.63,W-64*sc);
    ctx.textAlign='center';ctx.textBaseline='middle';
    if(s.cta){ctx.font=FB(9.5*sc,500);ctx.fillStyle=ac;ctx.globalAlpha=ao;ctx.fillText(trunc(s.cta,W-64*sc,FB(9.5*sc,500)),xC,H*0.84);ctx.globalAlpha=1;}
    numIdx(W-32*sc,H*0.38,'right');

  /* ══════════════════════════════════════
     RAW — brutalist, type only, zero decoration
  ══════════════════════════════════════ */
  } else {
    grain(0.8);
    ctx.fillStyle=tc2;ctx.textAlign='left';ctx.textBaseline='top';ctx.font=FM(9*sc);
    if(s.sub){ctx.globalAlpha=0.35;ctx.fillText(trunc(s.sub,W-56*sc,FM(9*sc)),28*sc,28*sc);ctx.globalAlpha=1;}
    ctx.textBaseline='middle';
    wt(s.title,28*sc,H*0.5,W-56*sc,fs*lh,FD(fs,700));
    bodyTxt(s.body,28*sc,H*0.73,W-56*sc);
    // single hairline at bottom
    ctx.fillStyle=ac;ctx.globalAlpha=ao*0.4;ctx.fillRect(28*sc,H-32*sc,W-56*sc,0.5*sc);ctx.globalAlpha=1;
    if(s.handle){ctx.font=FM(7.5*sc);ctx.fillStyle=tc2;ctx.globalAlpha=0.18;ctx.textAlign='left';ctx.textBaseline='bottom';ctx.fillText(trunc(s.handle,W-56*sc,FM(7.5*sc)),28*sc,H-16*sc);ctx.globalAlpha=1;}
  }
  ctx.restore();
}

/* ── DRAW ELEMENTS ── */
function drawEl(ctx,W,H,sc,el){
  const op=(el.opacity??100)/100;if(op<=0)return;
  const ex=el.xPct/100*W,ey=el.yPct/100*H;
  const ew=el.wPct/100*W,eh=el.hPct/100*H;
  ctx.save();ctx.translate(ex,ey);ctx.rotate((el.rotation||0)*Math.PI/180);ctx.globalAlpha=op;
  const r=(el.radius??0)*sc/4;
  const sw=(el.strokeW??1.5)*sc/2;
  const col=el.color||'#c0392b';
  const fil=el.fill;
  const hasFill=fil&&fil!=='transparent'&&fil!=='none';

  /* helper: fill+stroke a path already defined */
  function stroke(){ctx.strokeStyle=col;ctx.lineWidth=sw;ctx.stroke();}
  function fillStroke(){if(hasFill){ctx.fillStyle=fil;ctx.fill();}stroke();}

  /* shapes with fill support */
  if(['rect','circle','triangle','diamond','star'].includes(el.type)){
    ctx.beginPath();
    if(el.type==='rect')    ctx.roundRect(-ew/2,-eh/2,ew,eh,r);
    else if(el.type==='circle') ctx.arc(0,0,Math.min(ew,eh)/2,0,Math.PI*2);
    else if(el.type==='triangle'){ctx.moveTo(0,-eh/2);ctx.lineTo(ew/2,eh/2);ctx.lineTo(-ew/2,eh/2);ctx.closePath();}
    else if(el.type==='diamond'){ctx.moveTo(0,-eh/2);ctx.lineTo(ew/2,0);ctx.lineTo(0,eh/2);ctx.lineTo(-ew/2,0);ctx.closePath();}
    else if(el.type==='star'){
      const pts=5,or2=Math.min(ew,eh)/2,ir2=or2*0.42;
      for(let i=0;i<pts*2;i++){const a=i*Math.PI/pts-Math.PI/2;const rr=i%2===0?or2:ir2;i===0?ctx.moveTo(Math.cos(a)*rr,Math.sin(a)*rr):ctx.lineTo(Math.cos(a)*rr,Math.sin(a)*rr);}
      ctx.closePath();
    }
    fillStroke();

  } else if(el.type==='btn-stroke'){
    ctx.beginPath();ctx.roundRect(-ew/2,-eh/2,ew,eh,r);stroke();
    if(el.text){ctx.font=`${el.weight||500} ${(el.size||14)*sc/2}px ${fntCSS(el.fontId||'dmsans')}`;ctx.fillStyle=col;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(trunc2(ctx,el.text,ew-10*sc),0,0);}

  } else if(el.type==='btn-fill'){
    ctx.beginPath();ctx.roundRect(-ew/2,-eh/2,ew,eh,r);
    ctx.fillStyle=hasFill?fil:'#c0392b';ctx.fill();stroke();
    if(el.text){ctx.font=`${el.weight||500} ${(el.size||14)*sc/2}px ${fntCSS(el.fontId||'dmsans')}`;ctx.fillStyle=el.color||'#ffffff';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(trunc2(ctx,el.text,ew-10*sc),0,0);}

  } else if(el.type==='text'){
    ctx.font=`${el.weight||400} ${(el.size||16)*sc/2}px ${fntCSS(el.fontId||'playfair')}`;
    ctx.fillStyle=col;ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillText(el.text||'Texto',0,0);

  } else if(el.type==='line'){
    ctx.beginPath();ctx.moveTo(-ew/2,0);ctx.lineTo(ew/2,0);stroke();

  } else if(el.type==='dbl-line'){
    const gap=eh/2;
    ctx.beginPath();ctx.moveTo(-ew/2,-gap);ctx.lineTo(ew/2,-gap);ctx.moveTo(-ew/2,gap);ctx.lineTo(ew/2,gap);stroke();

  } else if(el.type==='arrow'){
    ctx.beginPath();ctx.moveTo(-ew/2,0);ctx.lineTo(ew/2-eh*0.3,0);stroke();
    ctx.beginPath();ctx.moveTo(ew/2,0);ctx.lineTo(ew/2-eh*0.45,-eh*0.35);ctx.lineTo(ew/2-eh*0.45,eh*0.35);ctx.closePath();
    ctx.fillStyle=col;ctx.fill();

  } else if(el.type==='arc-arrow'){
    /* curved arc arrow — retro editorial style */
    const rad=Math.min(ew,eh)*0.4;
    ctx.beginPath();ctx.arc(0,0,rad,-Math.PI*0.85,Math.PI*0.05);stroke();
    /* arrowhead */
    const ae=Math.PI*0.05,ax2=rad*Math.cos(ae),ay2=rad*Math.sin(ae);
    const aLen=sw*5;const aNorm=ae+Math.PI/2;
    ctx.beginPath();
    ctx.moveTo(ax2,ay2);
    ctx.lineTo(ax2+Math.cos(ae-0.7)*aLen,ay2+Math.sin(ae-0.7)*aLen);
    ctx.moveTo(ax2,ay2);
    ctx.lineTo(ax2+Math.cos(aNorm-0.3)*aLen,ay2+Math.sin(aNorm-0.3)*aLen);
    stroke();

  } else if(el.type==='cross'){
    const s2=Math.min(ew,eh)/2;
    ctx.beginPath();ctx.moveTo(-s2,0);ctx.lineTo(s2,0);ctx.moveTo(0,-s2);ctx.lineTo(0,s2);stroke();

  } else if(el.type==='wave'){
    ctx.beginPath();const amp=eh/2,steps=Math.ceil(ew);
    ctx.moveTo(-ew/2,0);
    for(let xi=0;xi<=steps;xi++){const t=xi/steps;ctx.lineTo(-ew/2+t*ew,Math.sin(t*Math.PI*4)*amp);}
    stroke();

  } else if(el.type==='zigzag'){
    const segs=8,segW=ew/segs;
    ctx.beginPath();ctx.moveTo(-ew/2,0);
    for(let i=0;i<=segs;i++){ctx.lineTo(-ew/2+i*segW,(i%2===0?-1:1)*eh/2);}
    stroke();

  } else if(el.type==='bracket'){
    /* [ ] style — two vertical lines with horizontal caps */
    const capW=ew*0.2;
    ctx.beginPath();
    ctx.moveTo(-ew/2+capW,-eh/2);ctx.lineTo(-ew/2,-eh/2);ctx.lineTo(-ew/2,eh/2);ctx.lineTo(-ew/2+capW,eh/2);
    ctx.moveTo(ew/2-capW,-eh/2);ctx.lineTo(ew/2,-eh/2);ctx.lineTo(ew/2,eh/2);ctx.lineTo(ew/2-capW,eh/2);
    stroke();

  } else if(el.type==='corner-mark'){
    /* registration corner marks — film/print style */
    const arm=Math.min(ew,eh)*0.42;
    ctx.beginPath();
    ctx.moveTo(-arm,0);ctx.lineTo(0,0);ctx.lineTo(0,-arm);  /* top-left corner */
    stroke();
    /* plus echo */
    ctx.beginPath();ctx.arc(0,0,arm*0.18,0,Math.PI*2);stroke();

  } else if(el.type==='film-frame'){
    /* 35mm film frame — perforations on sides */
    const fw=ew,fh=eh;const ph2=fh*0.08,pw2=fw*0.08;const gap=fh*0.14;
    ctx.beginPath();ctx.roundRect(-fw/2,-fh/2,fw,fh,r);stroke();
    /* inner frame */
    const inset=fw*0.1;
    ctx.beginPath();ctx.rect(-fw/2+inset,-fh/2+inset,fw-inset*2,fh-inset*2);stroke();
    /* perforations left */
    const numPerf=3;
    for(let i=0;i<numPerf;i++){
      const py=-fh*0.3+i*fh*0.3;
      ctx.beginPath();ctx.roundRect(-fw/2+pw2*0.2,py-ph2/2,pw2,ph2,2);stroke();
      ctx.beginPath();ctx.roundRect(fw/2-pw2-pw2*0.2,py-ph2/2,pw2,ph2,2);stroke();
    }

  } else if(el.type==='halftone'){
    /* halftone dot pattern — retro print */
    const dotR=Math.min(ew,eh)*0.06;const spacing=dotR*3;
    ctx.fillStyle=col;
    for(let gy=-eh/2;gy<eh/2;gy+=spacing){
      for(let gx=-ew/2;gx<ew/2;gx+=spacing){
        const dist=Math.sqrt(gx*gx+gy*gy)/Math.min(ew,eh)*2;
        const dr=dotR*(1-dist*0.5);
        if(dr>0.5){ctx.beginPath();ctx.arc(gx,gy,dr,0,Math.PI*2);ctx.fill();}
      }
    }

  } else if(el.type==='concentric'){
    /* concentric rings — analog oscilloscope / vinyl */
    const maxR=Math.min(ew,eh)/2;const rings=5;
    for(let i=1;i<=rings;i++){
      ctx.beginPath();ctx.arc(0,0,maxR*(i/rings),0,Math.PI*2);
      ctx.strokeStyle=col;ctx.lineWidth=sw*(1-(i/rings)*0.5);ctx.stroke();
    }

  } else if(el.type==='dot-grid'){
    /* evenly spaced dots — graph paper / editorial */
    const dotR2=sw*0.9;const spacing2=Math.min(ew,eh)*0.18;
    ctx.fillStyle=col;
    for(let gy=-eh/2;gy<=eh/2;gy+=spacing2)
      for(let gx=-ew/2;gx<=ew/2;gx+=spacing2){
        ctx.beginPath();ctx.arc(gx,gy,dotR2,0,Math.PI*2);ctx.fill();
      }

  } else if(el.type==='tick-line'){
    /* ruler tick line — measurement / editorial */
    ctx.beginPath();ctx.moveTo(-ew/2,0);ctx.lineTo(ew/2,0);stroke();
    const ticks=10;const tickH=eh/2;
    for(let i=0;i<=ticks;i++){
      const tx=-ew/2+(i/ticks)*ew;
      const th=i===0||i===ticks?tickH:i===ticks/2?tickH*0.7:tickH*0.4;
      ctx.beginPath();ctx.moveTo(tx,-th);ctx.lineTo(tx,th);stroke();
    }
  }
  ctx.restore();
}
function trunc2(ctx,text,maxW){
  let t=text;while(t.length>1&&ctx.measureText(t+'…').width>maxW)t=t.slice(0,-1);
  return ctx.measureText(text).width>maxW?t+'…':text;
}

/* ── IMAGE ── */
function onImg(e){
  const file=e.target.files[0];if(!file)return;
  const r=new FileReader();r.onload=ev=>{
    const url=ev.target.result;slides[cur].img=url;
    const img=new Image();img.onload=()=>{imgCache[url]=img;sched();};img.src=url;imgCache[url]=img;
    document.getElementById('img-prev').src=url;document.getElementById('img-prev').style.display='block';
    document.getElementById('img-clr').style.display='block';toast('Imagem carregada');
  };r.readAsDataURL(file);
}
function clearImg(){slides[cur].img=null;document.getElementById('img-prev').style.display='none';document.getElementById('img-clr').style.display='none';sched();toast('Imagem removida');}

/* ── SLIDES ── */
function sel(i){cur=i;selElem=null;renderAll();}
function addSlide(){const b=slides[cur]||{};slides.splice(cur+1,0,mkSlide({bg:b.bg,accent:b.accent,fontId:b.fontId}));sel(cur+1);toast('Slide adicionado');}
function dupSlide(){slides.splice(cur+1,0,JSON.parse(JSON.stringify(slides[cur])));sel(cur+1);toast('Slide duplicado');}
function delSlide(e,i){e.stopPropagation();if(slides.length===1){toast('Mínimo 1 slide');return;}slides.splice(i,1);if(cur>=slides.length)cur=slides.length-1;renderAll();}
function nav(d){cur=Math.max(0,Math.min(slides.length-1,cur+d));selElem=null;renderAll();}

/* ── EDITOR LOAD ── */
function loadEditor(){
  const s=slides[cur];
  document.getElementById('iT').value=s.title;document.getElementById('iS').value=s.sub;
  document.getElementById('iB').value=s.body;document.getElementById('iC').value=s.cta;
  document.getElementById('iH').value=s.handle;
  document.getElementById('fszv').textContent=s.fontSize;
