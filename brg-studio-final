function renderOverlay(){
  const ov=document.getElementById('ov');const ctx=ov.getContext('2d');
  const W=ov.width,H=ov.height;ctx.clearRect(0,0,W,H);
  if(!selElem)return;
  const el=slides[cur].elements.find(e=>e.id===selElem);if(!el)return;
  const sc=W/480;
  const ex=el.xPct/100*W,ey=el.yPct/100*H,ew=el.wPct/100*W,eh=el.hPct/100*H;
  ctx.save();ctx.translate(ex,ey);ctx.rotate((el.rotation||0)*Math.PI/180);
  ctx.strokeStyle='rgba(192,57,43,.9)';ctx.lineWidth=1.2*sc;ctx.setLineDash([4*sc,3*sc]);
  ctx.strokeRect(-ew/2,-eh/2,ew,eh);ctx.setLineDash([]);
  const hc=5*sc;
  [[-ew/2,-eh/2],[ew/2,-eh/2],[-ew/2,eh/2],[ew/2,eh/2],[0,-eh/2],[0,eh/2],[-ew/2,0],[ew/2,0]].forEach(([hx,hy])=>{
    ctx.fillStyle='#fff';ctx.beginPath();ctx.arc(hx,hy,hc,0,Math.PI*2);ctx.fill();
    ctx.strokeStyle='rgba(192,57,43,.9)';ctx.lineWidth=0.8*sc;ctx.setLineDash([]);ctx.stroke();
  });
