  // BG
  ctx.fillStyle=s.bg||'#0a0a0a';ctx.fillRect(0,0,W,H);
  if(s.img&&imgCache[s.img]?.complete){
    ctx.save();
    if(s.blur>0)ctx.filter=`blur(${s.blur*sc*0.35}px)`;
    const img=imgCache[s.img];
    const iz=img.naturalWidth,ih2=img.naturalHeight;
    // cover-fit: scale so image fills canvas without distortion
    const zoom=(s.zoom||100)/100;
    const scaleBase=Math.max(W/iz,H/ih2)*zoom;
    const dw=iz*scaleBase, dh=ih2*scaleBase;
    // position offset in px, driven by PX/PY sliders (-50..50%)
    const ox=((s.imgPX||0)/100)*(dw-W);
    const oy=((s.imgPY||0)/100)*(dh-H);
    const dx=(W-dw)/2 - ox;
    const dy=(H-dh)/2 - oy;
    ctx.drawImage(img,dx,dy,dw,dh);
    ctx.filter='none';ctx.restore();
  }
  if(s.overlay>0){ctx.fillStyle=`rgba(0,0,0,${s.overlay/100})`;ctx.fillRect(0,0,W,H);}
  drawLayout(ctx,W,H,sc,s,idx);
  s.elements.forEach(el=>drawEl(ctx,W,H,sc,el));
}

function drawLayout(ctx,W,H,sc,s,idx){
  const ac=s.accent||'#c0392b',ao=(s.acOp??100)/100,tc2=s.tc||'#ebebeb';
  const aln=s.align||'center',lay=s.layout||'minimal';
  const fs=(s.fontSize||40)*sc,fnt=fntCSS(s.fontId);
  const lh=s.lineHeight??1.2,ls=(s.letterSpacing??0)*sc;
  const tso=s.textShadow??0,tsop=(s.textShadowOp??0)/100;
  ctx.save();
  const xC=W/2,xL=38*sc,xR=W-38*sc;
  const xP=aln==='left'?xL:aln==='right'?xR:xC;
  const FD=(sz,w,it)=>`${it?'italic ':''} ${w||400} ${sz}px ${fnt}`;
  const FB=(sz,w)=>`${w||300} ${sz}px 'DM Sans',sans-serif`;
  const FM=(sz)=>`400 ${sz}px 'DM Mono',monospace`;
  const ax=(al)=>al==='center'?xC:al==='right'?xR:xL;

  function applyTextShadow(col){
    if(tso>0&&tsop>0)ctx.shadowColor=col==='dark'?`rgba(0,0,0,${tsop})`:`rgba(0,0,0,${tsop})`,ctx.shadowBlur=tso*sc;
    else ctx.shadowColor='transparent',ctx.shadowBlur=0;
  }
  function clearShadow(){ctx.shadowColor='transparent';ctx.shadowBlur=0;}

  // WRAP ENGINE
  function wrapLines(text,maxW,style){
    if(!text)return[];ctx.font=style;
    const words=text.split(' ');const lines=[];let line='';
    for(const w of words){
      const alone=ctx.measureText(w).width;
      const sw=alone>maxW?trunc(w,maxW,style):w;
      const test=line?line+' '+sw:sw;
      if(ctx.measureText(test).width>maxW&&line){lines.push(line);line=sw;}else line=test;
    }
    if(line)lines.push(line);return lines;
  }
  function trunc(word,maxW,style){
    ctx.font=style;let t=word;
    while(t.length>1&&ctx.measureText(t+'…').width>maxW)t=t.slice(0,-1);
    return t+'…';
  }
  function wt(text,x,y,maxW2,lhm,style){
    if(!text)return 0;ctx.font=style;
    ctx.letterSpacing=ls+'px';
    const lines=wrapLines(text,maxW2,style);
    const lhpx=(lhm||fs*lh);
    const sy=y-((lines.length-1)*lhpx)/2;
    applyTextShadow('dark');
    lines.forEach((l,i)=>ctx.fillText(l,ax(aln),sy+i*lhpx));
    clearShadow();ctx.letterSpacing='0px';
    return lines.length*lhpx;
  }
  function wtTop(text,startY,maxW2,lhm,style,al2){
    if(!text)return startY;ctx.font=style;
    ctx.letterSpacing=ls+'px';
    const lines=wrapLines(text,maxW2,style);
    const lhpx=lhm||fs*lh;const a2=ax(al2||aln);
    applyTextShadow('dark');
    lines.forEach((l,i)=>ctx.fillText(l,a2,startY+i*lhpx));
    clearShadow();ctx.letterSpacing='0px';
    return startY+lines.length*lhpx;
  }
  function bodyTxt(txt,x,y,maxW2){
    if(!txt)return;const style=FB(12*sc,300);ctx.font=style;
    ctx.fillStyle=tc2;ctx.globalAlpha=0.62;ctx.textBaseline='middle';ctx.textAlign=aln;
    const lines=wrapLines(txt,maxW2||W-76*sc,style);
    const a2=ax(aln);
    applyTextShadow('dark');
    lines.forEach((l,i)=>ctx.fillText(l,a2,y+i*17*sc));
    clearShadow();ctx.globalAlpha=1;
  }
  function ctaTxt(txt,x,y){
    if(!txt)return;const style=FB(9.5*sc,500);ctx.font=style;ctx.fillStyle=ac;ctx.globalAlpha=ao;ctx.textBaseline='middle';
    const safe=ctx.measureText(txt).width>W-80*sc?trunc(txt,W-80*sc,style):txt;
    ctx.fillText(safe,x,y);ctx.globalAlpha=1;
  }
  function ovl(txt,x,y,al2){
    if(!txt)return;ctx.save();ctx.font=FM(8.5*sc);ctx.fillStyle=ac;ctx.globalAlpha=ao;
    ctx.textAlign=al2||'left';ctx.textBaseline='middle';ctx.letterSpacing=(1.8*sc)+'px';
    const up=txt.toUpperCase();const safe=ctx.measureText(up).width>W-80*sc?trunc(up,W-80*sc,FM(8.5*sc)):up;
    ctx.fillText(safe,al2==='center'?xC:al2==='right'?xR:x,y);
    ctx.letterSpacing='0px';ctx.restore();ctx.globalAlpha=1;
  }
  function numIdx(x,y,al2){
    if(!s.showNum)return;ctx.save();ctx.font=FM(8*sc);ctx.fillStyle=ac;ctx.globalAlpha=ao*0.4;
    ctx.textAlign=al2||'right';ctx.textBaseline='middle';ctx.fillText(String(idx+1).padStart(2,'0'),x,y);
    ctx.restore();ctx.globalAlpha=1;
  }
  function aFill(x,y,w2,h2){ctx.fillStyle=ac;ctx.globalAlpha=ao;ctx.fillRect(x,y,w2,h2);ctx.globalAlpha=1;}
  function aStk(lw,fn){ctx.save();ctx.strokeStyle=ac;ctx.globalAlpha=ao;ctx.lineWidth=lw;fn();ctx.stroke();ctx.restore();ctx.globalAlpha=1;}
  // grain — subtle, calibrated per layout
  function grain(intensity){
    const key=`${W}x${H}x${Math.round(intensity*10)}`;
    if(!grainCache[key]){
      const oc=document.createElement('canvas');oc.width=W;oc.height=H;
      const oc2=oc.getContext('2d');const sz=1.8;
      for(let gy=0;gy<H;gy+=sz)for(let gx=0;gx<W;gx+=sz){
        const v=Math.random()*255;
        oc2.fillStyle=`rgba(${v},${v},${v},${intensity*0.018})`;
        oc2.fillRect(gx,gy,sz,sz);
      }
      grainCache[key]=oc;
      const keys=Object.keys(grainCache);if(keys.length>12)delete grainCache[keys[0]];
    }
    ctx.drawImage(grainCache[key],0,0);
  }

  // scanlines — subtle film texture
  function scanlines(op){
    ctx.fillStyle=`rgba(0,0,0,${op})`;
    for(let y=0;y<H;y+=3.2*sc) ctx.fillRect(0,y,W,1.2*sc);
  }

  // corner marks (registration / fragment style)
  function cornerMarks(size,pad,lw,opacity){
    const m=size*sc,p=pad*sc;
    [[p,p,1,1],[W-p,p,-1,1],[p,H-p,1,-1],[W-p,H-p,-1,-1]].forEach(([x,y,dx,dy])=>{
      ctx.save();ctx.strokeStyle=ac;ctx.globalAlpha=ao*opacity;ctx.lineWidth=lw*sc;
      ctx.beginPath();ctx.moveTo(x+dx*m,y);ctx.lineTo(x,y);ctx.lineTo(x,y+dy*m);ctx.stroke();
      ctx.restore();ctx.globalAlpha=1;
    });
  }

  ctx.fillStyle=tc2;ctx.textBaseline='middle';ctx.textAlign=aln;

  /* ══════════════════════════════════════
     MINIMAL — clean editorial, two rules, generous space
  ══════════════════════════════════════ */
  if(lay==='minimal'){
    // top hairline
    ctx.fillStyle=ac;ctx.globalAlpha=ao*0.5;ctx.fillRect(xL,26*sc,W-76*sc,0.8*sc);ctx.globalAlpha=1;
    // overline
    if(s.sub){
      ctx.save();ctx.font=FM(8.5*sc);ctx.fillStyle=ac;ctx.globalAlpha=ao;
      ctx.textAlign=aln;ctx.textBaseline='middle';ctx.letterSpacing=(ls+1.6*sc)+'px';
      ctx.fillText(trunc(s.sub.toUpperCase(),W-76*sc,FM(8.5*sc)),ax(aln),42*sc);
      ctx.letterSpacing='0px';ctx.restore();ctx.globalAlpha=1;
    }
    // title
    ctx.fillStyle=tc2;ctx.textAlign=aln;ctx.textBaseline='middle';
    const tyM=s.body?H*0.43:H*0.5;
    wt(s.title,xP,tyM,W-76*sc,fs*lh,FD(fs,700));
    bodyTxt(s.body,xP,H*0.63,W-76*sc);
    // footer
    if(s.cta||s.handle){
      ctx.fillStyle=ac;ctx.globalAlpha=ao*0.35;ctx.fillRect(xL,H-44*sc,W-76*sc,0.6*sc);ctx.globalAlpha=1;
      ctx.textBaseline='middle';
      if(s.cta){ctx.font=FB(9.5*sc,500);ctx.fillStyle=ac;ctx.globalAlpha=ao;ctx.textAlign='left';ctx.fillText(trunc(s.cta,W/2-10*sc,FB(9.5*sc,500)),xL,H-28*sc);ctx.globalAlpha=1;}
      if(s.handle){ctx.font=FM(7.5*sc);ctx.fillStyle=tc2;ctx.globalAlpha=0.22;ctx.textAlign='right';ctx.fillText(trunc(s.handle,W/2-10*sc,FM(7.5*sc)),W-xL,H-28*sc);ctx.globalAlpha=1;}
    }
    numIdx(W-xL,41*sc,'right');

  /* ══════════════════════════════════════
     EDITORIAL — newspaper / magazine structure
  ══════════════════════════════════════ */
  } else if(lay==='editorial'){
    const mg=24*sc;const mw=W-mg*2;
    // top double rule
    ctx.fillStyle=ac;ctx.globalAlpha=ao;ctx.fillRect(mg,24*sc,mw,1.8*sc);ctx.globalAlpha=1;
    ctx.fillStyle=ac;ctx.globalAlpha=ao*0.25;ctx.fillRect(mg,27.5*sc,mw,0.5*sc);ctx.globalAlpha=1;
    // category tag
    if(s.sub){
      ctx.save();ctx.font=FB(8.5*sc,600);ctx.fillStyle=ac;ctx.globalAlpha=ao;
      ctx.textAlign='left';ctx.textBaseline='middle';ctx.letterSpacing=(ls+1.4*sc)+'px';
      ctx.fillText(trunc(s.sub.toUpperCase(),mw,FB(8.5*sc,600)),mg,40*sc);
      ctx.letterSpacing='0px';ctx.restore();ctx.globalAlpha=1;
    }
    const tTop=s.sub?54*sc:36*sc;
    ctx.fillStyle=tc2;ctx.textAlign=aln;ctx.textBaseline='top';
    const te=wtTop(s.title,tTop,mw,fs*lh,FD(fs,700),aln)+4*sc;
    // rule after title
    ctx.fillStyle=ac;ctx.globalAlpha=ao*0.35;ctx.fillRect(mg,te+3*sc,mw,0.5*sc);ctx.globalAlpha=1;
    bodyTxt(s.body,ax(aln),te+20*sc,mw);
    // footer rule
    ctx.fillStyle=ac;ctx.globalAlpha=ao*0.35;ctx.fillRect(mg,H-42*sc,mw,0.5*sc);ctx.globalAlpha=1;
    if(s.cta){ctx.font=FB(9.5*sc,500);ctx.fillStyle=ac;ctx.globalAlpha=ao;ctx.textAlign='left';ctx.textBaseline='middle';ctx.fillText(trunc(s.cta,mw/2,FB(9.5*sc,500)),mg,H-26*sc);ctx.globalAlpha=1;}
    if(s.handle){ctx.font=FM(7.5*sc);ctx.fillStyle=tc2;ctx.globalAlpha=0.22;ctx.textAlign='right';ctx.textBaseline='middle';ctx.fillText(trunc(s.handle,mw/2,FM(7.5*sc)),W-mg,H-26*sc);ctx.globalAlpha=1;}
    numIdx(W-mg,40*sc,'right');

  /* ══════════════════════════════════════
     COVER — cinematic opener with geometry
  ══════════════════════════════════════ */
  } else if(lay==='cover'){
    grain(0.55);
    // accent bars top/bottom
    ctx.fillStyle=ac;ctx.globalAlpha=ao;ctx.fillRect(0,0,W,5*sc);ctx.fillRect(0,H-5*sc,W,5*sc);ctx.globalAlpha=1;
    // subtle grid
    ctx.strokeStyle=ac;ctx.globalAlpha=ao*0.018;ctx.lineWidth=0.5*sc;
    for(let gx=0;gx<W;gx+=28*sc){ctx.beginPath();ctx.moveTo(gx,0);ctx.lineTo(gx,H);ctx.stroke();}
    for(let gy=0;gy<H;gy+=28*sc){ctx.beginPath();ctx.moveTo(0,gy);ctx.lineTo(W,gy);ctx.stroke();}
    ctx.globalAlpha=1;
    // center vertical divider ghost
    ctx.strokeStyle=tc2;ctx.globalAlpha=0.03;ctx.lineWidth=0.5*sc;
    ctx.beginPath();ctx.moveTo(xC,H*0.1);ctx.lineTo(xC,H*0.9);ctx.stroke();ctx.globalAlpha=1;
    // brand tag top center
    if(s.sub){
      ctx.save();ctx.font=FM(8.5*sc);ctx.fillStyle=ac;ctx.globalAlpha=ao;
      ctx.textAlign='center';ctx.textBaseline='middle';ctx.letterSpacing=(2.2*sc)+'px';
      ctx.fillText(trunc(s.sub.toUpperCase(),W-80*sc,FM(8.5*sc)),xC,H*0.19);
      ctx.letterSpacing='0px';ctx.restore();ctx.globalAlpha=1;
    }
    // separator
    ctx.fillStyle=ac;ctx.globalAlpha=ao*0.55;ctx.fillRect(xC-20*sc,H*0.26,40*sc,0.7*sc);ctx.globalAlpha=1;
    // main title
    ctx.fillStyle=tc2;ctx.textAlign='center';ctx.textBaseline='middle';
    wt(s.title,xC,H*0.5,W-80*sc,fs*lh,FD(fs,700));
    bodyTxt(s.body,xC,H*0.68,W-80*sc);
    ctx.textAlign='center';ctx.textBaseline='middle';
    if(s.cta){ctx.font=FB(9.5*sc,500);ctx.fillStyle=ac;ctx.globalAlpha=ao;ctx.fillText(trunc(s.cta,W-80*sc,FB(9.5*sc,500)),xC,H*0.84);ctx.globalAlpha=1;}

  /* ══════════════════════════════════════
     LO-FI — analog film aesthetic
  ══════════════════════════════════════ */
  } else if(lay==='lofi'){
    grain(0.9);
    scanlines(0.007);
    // ghost letterform
    ctx.font=`700 ${fs*2.6}px ${fnt}`;ctx.fillStyle=tc2;ctx.globalAlpha=0.018;
    ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillText((s.title||'').substring(0,4).toUpperCase(),xC,H*0.5);ctx.globalAlpha=1;
    // accent dot + overline
    ctx.beginPath();ctx.arc(32*sc,32*sc,3*sc,0,Math.PI*2);
    ctx.fillStyle=ac;ctx.globalAlpha=ao;ctx.fill();ctx.globalAlpha=1;
    if(s.sub){
      ctx.save();ctx.font=FM(8.5*sc);ctx.fillStyle=ac;ctx.globalAlpha=ao*0.8;
      ctx.textAlign='left';ctx.textBaseline='middle';ctx.letterSpacing=(ls+1.4*sc)+'px';
      ctx.fillText(trunc(s.sub.toUpperCase(),W-76*sc,FM(8.5*sc)),46*sc,32*sc);
      ctx.letterSpacing='0px';ctx.restore();ctx.globalAlpha=1;
    }
    ctx.fillStyle=tc2;ctx.textAlign='left';ctx.textBaseline='middle';
    wt(s.title,xL,s.body?H*0.44:H*0.5,W-60*sc,fs*lh,FD(fs,700));
    bodyTxt(s.body,xL,H*0.63,W-60*sc);
    // bottom handle
    if(s.handle){ctx.font=FM(7.5*sc);ctx.fillStyle=tc2;ctx.globalAlpha=0.18;ctx.textAlign='right';ctx.textBaseline='bottom';ctx.fillText(trunc(s.handle,W/2,FM(7.5*sc)),W-24*sc,H-16*sc);ctx.globalAlpha=1;}
    // bottom rule
    ctx.fillStyle=ac;ctx.globalAlpha=ao*0.2;ctx.fillRect(xL,H-34*sc,W-76*sc,0.5*sc);ctx.globalAlpha=1;
    numIdx(W-xL,32*sc,'right');

  /* ══════════════════════════════════════
     STROKE BOX — fashion editorial, vector frame
  ══════════════════════════════════════ */
  } else if(lay==='stroke-box'){
    // precise dot grid
    ctx.fillStyle=ac;ctx.globalAlpha=ao*0.045;
    const gstep=22*sc;
    for(let gx=gstep;gx<W-gstep/2;gx+=gstep)
      for(let gy=gstep;gy<H-gstep/2;gy+=gstep){
        ctx.beginPath();ctx.arc(gx,gy,0.65*sc,0,Math.PI*2);ctx.fill();
      }
    ctx.globalAlpha=1;
    // edge rules
    ctx.fillStyle=ac;ctx.globalAlpha=ao*0.35;
    ctx.fillRect(30*sc,26*sc,W-60*sc,0.5*sc);
    ctx.fillRect(30*sc,H-26*sc,W-60*sc,0.5*sc);
    ctx.globalAlpha=1;
    // overline above box
    if(s.sub){
      ctx.save();ctx.font=FM(8.5*sc);ctx.fillStyle=ac;ctx.globalAlpha=ao;
      ctx.textAlign='center';ctx.textBaseline='middle';ctx.letterSpacing=(ls+1.6*sc)+'px';
      ctx.fillText(trunc(s.sub.toUpperCase(),W-80*sc,FM(8.5*sc)),xC,H*0.28);
      ctx.letterSpacing='0px';ctx.restore();ctx.globalAlpha=1;
    }
    // title box
    ctx.font=FD(fs,700);
    const twm=Math.min(ctx.measureText(s.title||'').width,W-80*sc)+52*sc;
    const bxH=fs*1.75,bxX=(W-twm)/2,bxY=H*(s.body?0.36:0.4);
    // stroke rect
    ctx.strokeStyle=ac;ctx.globalAlpha=ao;ctx.lineWidth=1*sc;ctx.strokeRect(bxX,bxY,twm,bxH);ctx.globalAlpha=1;
    // corner crosshairs
    const ck=8*sc;
    [[bxX,bxY],[bxX+twm,bxY],[bxX,bxY+bxH],[bxX+twm,bxY+bxH]].forEach(([cx2,cy2])=>{
      ctx.save();ctx.strokeStyle=ac;ctx.globalAlpha=ao*0.5;ctx.lineWidth=0.6*sc;
      ctx.beginPath();ctx.moveTo(cx2-ck,cy2);ctx.lineTo(cx2+ck,cy2);
      ctx.moveTo(cx2,cy2-ck);ctx.lineTo(cx2,cy2+ck);ctx.stroke();ctx.restore();ctx.globalAlpha=1;
    });
    // title inside box
    ctx.fillStyle=tc2;ctx.textAlign='center';ctx.textBaseline='middle';ctx.font=FD(fs,700);
    applyTextShadow('dark');ctx.fillText(trunc(s.title||'',twm-20*sc,FD(fs,700)),xC,bxY+bxH/2);clearShadow();
    // body below box
    if(s.body){
      ctx.font=FB(11.5*sc,300);ctx.fillStyle=tc2;ctx.globalAlpha=0.55;ctx.textAlign='center';ctx.textBaseline='top';
      wrapLines(s.body,W-80*sc,FB(11.5*sc,300)).forEach((l,i)=>ctx.fillText(l,xC,bxY+bxH+16*sc+i*17*sc));
      ctx.globalAlpha=1;
    }
    ctx.textAlign='center';ctx.textBaseline='middle';
    if(s.cta){ctx.font=FB(9*sc,500);ctx.fillStyle=ac;ctx.globalAlpha=ao;ctx.fillText(trunc(s.cta,W-80*sc,FB(9*sc,500)),xC,H-16*sc);ctx.globalAlpha=1;}
    numIdx(W-34*sc,16*sc,'right');

  /* ══════════════════════════════════════
     ARCH — perfume / luxury oval frame
  ══════════════════════════════════════ */
  } else if(lay==='arch'){
    const cx2=W/2,cy2=H/2;
    const rx=W*0.34,ry=H*0.37;
    // outer ellipse
    ctx.strokeStyle=ac;ctx.globalAlpha=ao;ctx.lineWidth=0.9*sc;
    ctx.beginPath();ctx.ellipse(cx2,cy2,rx,ry,0,0,Math.PI*2);ctx.stroke();ctx.globalAlpha=1;
    // echo rings
    [rx+10*sc,rx-10*sc].forEach((r2,ri)=>{
      ctx.save();ctx.strokeStyle=ac;ctx.globalAlpha=ao*(ri===0?0.14:0.06);ctx.lineWidth=0.4*sc;
      ctx.beginPath();ctx.ellipse(cx2,cy2,r2,ry+(ri===0?10:-10)*sc,0,0,Math.PI*2);ctx.stroke();
      ctx.restore();ctx.globalAlpha=1;
    });
    // cardinal ticks
    [0,Math.PI/2,Math.PI,Math.PI*1.5].forEach(a=>{
      const tx=cx2+rx*Math.cos(a),ty=cy2+ry*Math.sin(a);
      const nx=Math.cos(a),ny=Math.sin(a);
      ctx.save();ctx.strokeStyle=ac;ctx.globalAlpha=ao*0.45;ctx.lineWidth=0.65*sc;
      ctx.beginPath();ctx.moveTo(tx-nx*7*sc,ty-ny*7*sc);ctx.lineTo(tx+nx*7*sc,ty+ny*7*sc);
      ctx.stroke();ctx.restore();ctx.globalAlpha=1;
    });
    // overline inside arch top
    if(s.sub){
      ctx.save();ctx.font=FM(8.5*sc);ctx.fillStyle=ac;ctx.globalAlpha=ao;
      ctx.textAlign='center';ctx.textBaseline='middle';ctx.letterSpacing=(ls+1.6*sc)+'px';
      ctx.fillText(trunc(s.sub.toUpperCase(),rx*1.3,FM(8.5*sc)),cx2,cy2-ry*0.64);
      ctx.letterSpacing='0px';ctx.restore();ctx.globalAlpha=1;
    }
    // title
    ctx.fillStyle=tc2;ctx.textAlign='center';ctx.textBaseline='middle';
    wt(s.title,cx2,cy2,rx*1.44,fs*lh,FD(fs,700));
    bodyTxt(s.body,cx2,cy2+ry*0.54,rx*1.6);
    ctx.textAlign='center';ctx.textBaseline='middle';
    if(s.cta){ctx.font=FB(9.5*sc,500);ctx.fillStyle=ac;ctx.globalAlpha=ao;ctx.fillText(trunc(s.cta,rx*1.6,FB(9.5*sc,500)),cx2,cy2+ry+20*sc);ctx.globalAlpha=1;}
    if(s.handle){ctx.font=FM(7.5*sc);ctx.fillStyle=tc2;ctx.globalAlpha=0.18;ctx.textAlign='center';ctx.textBaseline='bottom';ctx.fillText(trunc(s.handle,W-80*sc,FM(7.5*sc)),cx2,H-14*sc);ctx.globalAlpha=1;}

  /* ══════════════════════════════════════
     GRID LINES — blueprint / archival
  ══════════════════════════════════════ */
  } else if(lay==='grid'){
    const step=20*sc;
    ctx.strokeStyle=ac;ctx.globalAlpha=ao*0.055;ctx.lineWidth=0.4*sc;
    for(let y=0;y<H;y+=step){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();}
    for(let x=0;x<W;x+=step){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();}
    ctx.globalAlpha=1;
    // bold left accent stripe
    ctx.fillStyle=ac;ctx.globalAlpha=ao;ctx.fillRect(0,0,5*sc,H);ctx.globalAlpha=1;
    const lx=20*sc;
    if(s.sub){
      ctx.save();ctx.font=FM(8.5*sc);ctx.fillStyle=ac;ctx.globalAlpha=ao;
      ctx.textAlign='left';ctx.textBaseline='middle';ctx.letterSpacing=(ls+1.4*sc)+'px';
      ctx.fillText(trunc(s.sub.toUpperCase(),W-lx-32*sc,FM(8.5*sc)),lx,H*0.18);
      ctx.letterSpacing='0px';ctx.restore();ctx.globalAlpha=1;
    }
    ctx.fillStyle=tc2;ctx.textAlign='left';ctx.textBaseline='middle';
    wt(s.title,lx,s.body?H*0.43:H*0.5,W-lx-32*sc,fs*lh,FD(fs,700));
    bodyTxt(s.body,lx,H*0.63,W-lx-32*sc);
    // CTA in stroke pill
    if(s.cta){
      ctx.font=FB(9*sc,500);
      const cw=Math.min(ctx.measureText(s.cta).width,W-lx-32*sc)+22*sc;
      ctx.strokeStyle=ac;ctx.globalAlpha=ao;ctx.lineWidth=0.8*sc;ctx.strokeRect(lx,H*0.82-11*sc,cw,22*sc);ctx.globalAlpha=1;
      ctx.fillStyle=ac;ctx.globalAlpha=ao;ctx.textAlign='left';ctx.textBaseline='middle';ctx.fillText(trunc(s.cta,cw-12*sc,FB(9*sc,500)),lx+11*sc,H*0.82);ctx.globalAlpha=1;
    }
    numIdx(W-16*sc,14*sc,'right');

  /* ══════════════════════════════════════
     STAMP — circular seal / carimbão
  ══════════════════════════════════════ */
  } else if(lay==='stamp'){
    grain(0.6);
    const cx2=W/2,cy2=H/2,sr=H*0.285;
    // outer dashed circle
    ctx.save();ctx.strokeStyle=ac;ctx.globalAlpha=ao;ctx.lineWidth=1.1*sc;
    ctx.setLineDash([3.5*sc,3.5*sc]);ctx.beginPath();ctx.arc(cx2,cy2,sr,0,Math.PI*2);ctx.stroke();
    ctx.setLineDash([]);ctx.restore();ctx.globalAlpha=1;
    // inner thin circle
    ctx.save();ctx.strokeStyle=ac;ctx.globalAlpha=ao*0.3;ctx.lineWidth=0.4*sc;
    ctx.beginPath();ctx.arc(cx2,cy2,sr-8*sc,0,Math.PI*2);ctx.stroke();
    ctx.restore();ctx.globalAlpha=1;
    // h-rules inside circle
    [[cy2-fs*0.72],[cy2+fs*0.72]].forEach(([y])=>{
      ctx.save();ctx.strokeStyle=ac;ctx.globalAlpha=ao*0.22;ctx.lineWidth=0.45*sc;
      ctx.beginPath();ctx.moveTo(cx2-sr*0.5,y);ctx.lineTo(cx2+sr*0.5,y);ctx.stroke();
      ctx.restore();ctx.globalAlpha=1;
    });
    // centered title
    ctx.fillStyle=tc2;ctx.textAlign='center';ctx.textBaseline='middle';
    wt(s.title,cx2,cy2,sr*1.4,fs*lh,FD(fs,700));
    // curved sub text (top arc)
    if(s.sub){
      const t2=(s.sub||'').toUpperCase();
      ctx.save();ctx.font=FM(8*sc);ctx.fillStyle=ac;ctx.globalAlpha=ao;
      const ar=sr+2*sc,span=Math.min(t2.length*0.17,Math.PI*0.95),sa=-Math.PI/2-span/2;
      for(let i=0;i<t2.length;i++){
        const a=sa+i*(span/(Math.max(t2.length-1,1)));
        ctx.save();ctx.translate(cx2+ar*Math.cos(a),cy2+ar*Math.sin(a));
        ctx.rotate(a+Math.PI/2);ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(t2[i],0,0);ctx.restore();
      }
