/* ── AUTO-VARIATION SYSTEM ──
   Garante que cada slide de um carrossel tenha identidade própria:
   layout diferente, variações de alinhamento e tamanho de fonte.
   Mantém coerência visual (mesma paleta, mesma fonte base).
*/
const LAY_SEQUENCE = [
  'cover','editorial','minimal','type','split',
  'lofi','fragment','ticker','grid','stroke-box',
  'arch','stamp','raw'
];
const ALIGN_VARS = ['center','left','left','center','right','left','center'];
const FS_VARS    = [44,36,42,38,46,34,40,48,36,42];

function autoVariate(slides2, base){
  // pick a layout rotation offset per generation (random start)
  const offset = Math.floor(Math.random()*LAY_SEQUENCE.length);
  return slides2.map((s,i)=>{
    const lay = i===0 ? 'cover' : LAY_SEQUENCE[(offset+i) % LAY_SEQUENCE.length];
    const aln = ALIGN_VARS[i % ALIGN_VARS.length];
    const fsz = FS_VARS[i % FS_VARS.length];
    // slight font variety: keep base font for even slides, serif alt for odd
    const fontSeq = ['playfair','cormorant','spectral','fraunces','libre','imfell'];
    const fontId = i===0 ? (base.fontId||'playfair') : fontSeq[i % fontSeq.length];
    return mkSlide({
      ...s,
      layout: lay,
      align:  aln,
      fontSize: fsz,
      fontId,
      lineHeight: 1.15 + (i%3)*0.05,
      bg:    base.bg||'#0a0a0a',
      tc:    base.tc||'#ebebeb',
      accent:base.accent||'#c0392b',
    });
  });
}

