/* ── OPENAI IMAGE GENERATION ── */
/* HF token — embedded, no UI field needed */
const _HF_TOKEN = ''; // token passed by user via UI
let _imgSz = '1024x1024';
function setImgSz(sz, btn){
  _imgSz = sz;
  document.querySelectorAll('.img-sz-btn').forEach(b => b.className='img-sz-btn');
  btn.className = 'img-sz-btn on';
}

async function genImage(){
  const prompt = document.getElementById('imgPrompt').value.trim();
  if(!prompt){ toast('Descreva a imagem'); return; }

  const [w, h] = _imgSz.split('x').map(Number);
  const btn = document.getElementById('btnGenImg');
  const st  = document.getElementById('img-gen-st');
  const res = document.getElementById('gen-results');
  btn.disabled = true;
  document.getElementById('gi-ico').innerHTML = '<div class="spin"></div>';
  document.getElementById('gi-txt').textContent = 'Gerando...';
  st.textContent = 'Aguarde — ~15s...';
  res.innerHTML = '';

  try{
    const hfKey = (document.getElementById('hfKey').value || localStorage.getItem('hfkey') || '').trim();
    if(!hfKey){ toast('Cole seu HuggingFace token na aba Imagem'); btn.disabled=false; document.getElementById('gi-ico').textContent='✦'; document.getElementById('gi-txt').textContent='Gerar imagem'; return; }
    const API_URL = window._BRG_API || 'http://localhost:5000';
    const r = await fetch(API_URL + '/gerar', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ prompt, width: w, height: h, hf_token: hfKey })
    });
    if(!r.ok){
      const err = await r.json().catch(()=>({error:r.statusText}));
      throw new Error(err.error || r.statusText);
    }
    const data2 = await r.json();
    const src = data2.image;
    const d = document.createElement('div');
    d.className = 'gen-thumb';
    d.innerHTML = `<img src="${src}" alt="gerada"><div class="gen-thumb-apply">Usar como fundo</div>`;
    d.onclick = () => applyGenImage(src, d);
    res.appendChild(d);
    st.textContent = '✦ Pronta — clique para aplicar';
    btn.disabled = false;
    document.getElementById('gi-ico').textContent = '✦';
    document.getElementById('gi-txt').textContent = 'Gerar imagem';
  }catch(e){
    st.textContent = '⚠ ' + (e.message||'Erro ao gerar');
    console.error(e);
    btn.disabled = false;
    document.getElementById('gi-ico').textContent = '✦';
    document.getElementById('gi-txt').textContent = 'Gerar imagem';
  }
}

function applyGenImage(src, thumbEl){
  document.querySelectorAll('.gen-thumb').forEach(t => t.className='gen-thumb');
  thumbEl.className = 'gen-thumb on';
  const img = new Image();
  img.onload = () => {
    imgCache[src] = img;
    slides[cur].img = src;
    slides[cur].imgPX = 0; slides[cur].imgPY = 0; slides[cur].zoom = 100;
    document.getElementById('img-prev').src = src;
    document.getElementById('img-prev').style.display = 'block';
    document.getElementById('img-clr').style.display = 'block';
    document.getElementById('rPX').value = 0; document.getElementById('vPX').textContent = '0%';
    document.getElementById('rPY').value = 0; document.getElementById('vPY').textContent = '0%';
    document.getElementById('rZm').value = 100; document.getElementById('vZm').textContent = '100%';
    sched();
    toast('Imagem aplicada ao slide');
  };
  // No crossOrigin here — just display
  img.src = src;
}


/* ── TOAST ── */
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.className='show';clearTimeout(toast._t);toast._t=setTimeout(()=>t.className='',2600);}

/* ── KEYBOARD ── */
document.addEventListener('keydown',e=>{
  if(e.target.tagName==='INPUT'||e.target.tagName==='TEXTAREA')return;
  if(e.key==='ArrowRight'||e.key==='ArrowDown')nav(1);
  if(e.key==='ArrowLeft'||e.key==='ArrowUp')nav(-1);
  if(e.key==='n'||e.key==='N')addSlide();
  if(e.key==='d'||e.key==='D')dupSlide();
  if(e.key==='Escape'){selElem=null;schedCV();loadElList();document.getElementById('ep').style.display='none';}
  if((e.key==='Delete'||e.key==='Backspace')&&selElem)delSelEl();
});
window.addEventListener("resize",()=>{setupCV();schedCV();});

window._BRG_API='https://brg-studio-production.up.railway.app';
init();
